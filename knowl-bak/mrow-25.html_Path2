<div class="displaymath process-math" data-contains-math-knowls="">
\begin{align*}
\int x^2\sqrt{x^3+1}\dx{x}\amp=\int x^2\sqrt{y}\left(\frac{\dx{y}}{3x^2}\right)\\
\amp=\frac13\int y^{1/2}\dx{y}\\
\amp=\frac13\left(\frac{y^{3/2}}{3/2}\right)+c\\
\amp=\frac29\left(x^3+1\right)^{3/2}+c
\end{align*}
</div>
