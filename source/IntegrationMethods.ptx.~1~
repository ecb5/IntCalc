  </exercise>

  <exercise>
    

    <introduction>
      <!-- <p> -->
      <!--   The table below repeats the last three entries of <xref -->
      <!--   ref="TABLEBasicIntegration">Table</xref>. -->
      <!-- </p> -->
      <!-- <table xml:id="InvereTrigIntegrationTable"> -->
      <!--   <title>Inverse Trigonometric Substitution</title> -->
      <!--   <tabular halign="left"> -->
      <!--     <row bottom="major" header="yes"> -->
      <!--       <cell>Differentiation -->
      <!--       Rule</cell><cell><line>Integration Rule</line></cell> -->
      <!--     </row> -->
