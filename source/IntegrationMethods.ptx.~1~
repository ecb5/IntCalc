  <example xml:id="EXAMPLEIntTan">
    <title>The Integral of the Tangent Function</title>

    <p>
      Use <xref ref="IntRuleSin">Integration Rule</xref> to
      compute <m>\int\tan(x)\dx{x}</m> by making the substitution
      <md>
        <mrow>
          z=\cos(x),
        </mrow>
        <intertext>which means that</intertext>
        <mrow>\dx{z}=-\sin(x)\dx{x}</mrow>
        <intertext> or</intertext>
        <mrow>\textcolor{red}{-\dx{z}=\sin(x)\dx{z}}</mrow>
        </md>.
    </p>
    <p>
      Thus
      <md>
        <mrow>\int\tan(x)\dx{x} =
        \int\frac{\textcolor{red}{\sin(x)}}{\cos(x)}\textcolor{red}{\dx{x}}
        <!-- \amp -->
        <!--            =\int\frac{\sin(x)}{z}\cdot\frac{-\dx{z}}{\sin(x)}</mrow> -->
        \amp =-\int\frac{\dx{z}}{z}
        </mrow>
        <mrow>\amp =-\ln(z)+C</mrow>
        <mrow>\amp =(-1)\ln(\cos(x))+C</mrow>
        <mrow>\amp =\ln\left((\cos(x))^{-1}\right)+C</mrow>
        <mrow>\amp =\ln\left(\sec(x)\right)+C</mrow>
        </md>.
    </p>
  </example>
