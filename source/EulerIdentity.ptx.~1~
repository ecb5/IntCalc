<p>

  \textbf{Problem.}   We know that <m>y={{\mathrm{sin}}^{\mathrm{-}\mathrm{1}} \left(x\right)\ }</m> satisfies <m>\frac{dy}{dx}=\frac{1}{\sqrt{1-x^2}}</m> so that 
  <me>\int{\frac{1}{\sqrt{1-x^2}}\ dx}={{\mathrm{sin}}^{\mathrm{-}\mathrm{1}} \left(x\right)\ }+C</me> 
</p>
<p>


  \begin{enumerate}
  \item   Perform the substitution <m>ix=z</m> to transform the above integral into
  \end{enumerate}
</p>
<p>

  
  <me>\frac{1}{i}\int{\frac{1}{\sqrt{1+z^2}}\ dz}</me> 
</p>
<p>


  \begin{enumerate}
  \item  Perform the appropriate trigonometric substitution (you done it before) to show that
  \end{enumerate}
</p>
<p>

  
  <me>\frac{1}{i}\left({\mathrm{ln} (\ }z+\left(\sqrt{1+z^2}\right)\right)={{\mathrm{sin}}^{\mathrm{-}\mathrm{1}} \left(x\right)\ }+C</me> 
</p>
<p>


  \begin{enumerate}
  \item  Substitute <m>x=0</m> into the result from Part b to determine <m>C=0</m> and obtain
  \end{enumerate}
</p>
<p>

  
  <me>{\mathrm{(ln} \left(\sqrt{1-x^2}+ix\right)\ }=i{{\mathrm{sin}}^{\mathrm{-}\mathrm{1}} (x)\ }</me> 
</p>
<p>


  \begin{enumerate}
  \item  Labeling <m>t={{\mathrm{sin}}^{\mathrm{-}\mathrm{1}} (x)\ },\ </m>show that the equation in Part c can be rewritten as
  \end{enumerate}
</p>
<p>

  
  <me>{\mathrm{ln} \left({\mathrm{cos} \left(t\right)\ }+i{\mathrm{sin} \left(t\right)\ }\right)\ }=it</me> 
</p>
<p>

  and obtain Euler's Identity
</p>


