  <!--   <p> -->
  <!--     In light of <xref ref="DRILLIntSum"></xref>, it is common -->
  <!--     practice integrate each term of a differential and then combine -->
  <!--     all of the arbitrary constants into a single constant. -->
  <!--   </p> -->
