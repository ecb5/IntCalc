      <!--     <me>\int{\frac{25}{{\left(x-2\right)}^2\left(x^2+1\right)}}\ -->
      <!--     \dx{x}=-4{\mathrm{ln} \left(x-2\right)\ -->
      <!--     }-5{\left(x-2\right)}^{-1}+2{\mathrm{ln} -->
      <!--     \left(x^2+1\right)\ }-3{\mathrm{arctan} x\ }+c</me> -->


      <!--     The trick that we employed above is something you might -->
      <!--     want to remember.  It allows us to take our partial -->
