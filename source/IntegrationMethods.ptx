  <!--     ref="IntRuleInvSin"></xref>, <xref -->
  <!--     ref="IntRuleInvTan"></xref>, and <xref -->
  <!--     ref="IntRuleInvSec"></xref>, directly.  -->
  <!--     </p> -->
  <!--   </introduction> -->

  <!--   <task> -->
  <!--     <statement> -->
  <!--       <p> -->
  <!--         Use the substitution <m>x=\sin(\theta)</m> to compute -->
  <!--         <m>\int\frac{1}{\sqrt{1-x^2}}\dx{x}</m>. -->
  <!--       </p> -->
  <!--     </statement> -->
  <!--   </task> -->

  <!--   <task> -->
  <!--     <statement> -->
  <!--       <p> -->
  <!--         Use the substitution <m>x=\tan(\theta)</m> to compute -->
  <!--         <m>\int{\frac{1}{1+x^2}}\dx{x}</m>. -->
  <!--       </p> -->
  <!--     </statement> -->
  <!--   </task> -->

  <!--   <task> -->
  <!--     <statement> -->
  <!--       <p> -->
  <!--         Use the substitution <m>x=\sec(\theta)</m> to compute -->
  <!--         <m>\int\frac{1}{x\sqrt{x^2-1}}\dx{x}</m> -->
