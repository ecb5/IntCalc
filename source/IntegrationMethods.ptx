  <!--     For example is it -->
  <!--     clear to you that <m>\int \sin^2(x) +\cos^2(x) \dx{x} = x+C</m>? -->
  <!--     This is true simply because we can use the identity <m>\sin^2(x) -->
  <!--     +\cos^2(x)=1</m> to make the substitution -->
  <!--     <me>\int \sin^2(x) +\cos^2(x) \dx{x} = \int \dx{x}= x+C</me>. -->
  <!--   </p> -->
