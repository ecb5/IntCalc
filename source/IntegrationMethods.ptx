      <!--     <p> -->
      <!--       Bud -\- at this point, how much of the paper you wrote -->
      <!--       should we put in?  Will putting it in be too much at this -->
      <!--       point?  Should be some practice exercises first?  Should -->
      <!--       it be appendicized?  I<rsq/>m afraid I've already written too -->
      <!--       much on partial fractions decompositions.  I need your -->
      <!--       fresh view on this. -->
      <!--     </p> -->
      <!--   </aside> -->

      <!--   <p> -->
