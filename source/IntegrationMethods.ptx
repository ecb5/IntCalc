      <!--         mere trick. It is a very powerful technique, not just in -->
      <!--         differentiation and but in all of mathematics. -->
      <!--       </p> -->
      <!--       <p> -->
      <!--         The good news is that you can do any substitution you wish and -->
      <!--         as long as it is performed correctly, it is not wrong. -->
      <!--       </p> -->
      <!--       <p> -->
      <!--         But the bad news is that you can do any substitution you wish -->
      <!--         and as long as it is performed correctly, it is not wrong. -->
      <!--       </p> -->
