      <!--   <statement> -->
      <!--     <p> -->
      <!--       Confirm the identity: <m>\frac{1}{1-\sin^2(x) }= -->
      <!-- \frac12{\left[\frac{1}{1+\sin(x) } + \frac{1}{1-\sin(x) }\right] }</m> -->
      <!-- </p> -->
