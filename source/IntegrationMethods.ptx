      <!--         <introduction> -->
      <!--           <p> -->
      <!--             At this point we have know the integrals of the <m>\sin(x) </m>, -->
      <!--             <m>\cos(x) </m>, <m>\tan(x) </m>, and <m>\cot(x) </m>. The first two -->
      <!--             were immediate consequences of the differentiation rules, but the -->
      <!--             <m>\tan(x) </m>, and <m>\cot(x) </m> were harder. -->
